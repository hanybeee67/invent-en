# Everest Inventory System - Environment Variables
# Copy this file to .env and fill in your actual values

# ===== Security =====
# Manager password (will be hashed automatically)
MANAGER_PASSWORD=your_secure_password_here

# Session timeout in seconds (default: 1800 = 30 minutes)
SESSION_TIMEOUT=1800

# ===== POS 연동 API Key =====
# POS 서버의 INTERNAL_API_KEY 와 동일한 값으로 설정
# Render.com 환경변수 → INTERNAL_API_KEY
INTERNAL_API_KEY=your_internal_api_key_here

# ===== Google Drive =====
# Google Service Account JSON (paste entire JSON content)
GOOGLE_KEY_JSON={"type":"service_account","project_id":"..."}

# Drive folder ID for receipts
DRIVE_FOLDER_ID=your_folder_id_here

# ===== Application Settings =====
# Storage directory (leave empty to use default)
DATA_DIR=

# Feature flags
ENABLE_AUTO_BACKUP=true
BACKUP_RETENTION_DAYS=30
ENABLE_MOBILE_MODE=true

# ===== Development =====
# Set to 'development' or 'production'
ENVIRONMENT=production

# Enable debug logging
DEBUG=false
